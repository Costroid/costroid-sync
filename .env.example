# Current providers
OPENAI_ADMIN_KEY=sk-admin-...
ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# GitHub Copilot
GITHUB_PAT=ghp_...
GITHUB_ORG=your-org

# Google Gemini (Cloud Billing export file from BigQuery)
GEMINI_BILLING_EXPORT=/path/to/google-billing-export.csv
GEMINI_BILLING_PROJECT=your-gcp-project-id
# GEMINI_BILLING_SERVICE_FILTER=gemini,vertex

# GCP Billing (BigQuery Cloud Billing detailed export — broad, all GCP services)
GCP_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
GCP_BILLING_PROJECT=your-query-project
GCP_BILLING_TABLE=your-project.billing_export_data.gcp_billing_export_v1_XXXXXX
# Optional:
# GCP_BILLING_PROJECT_FILTER=your-gcp-project-id
# GCP_BILLING_SERVICE_FILTER=Vertex AI,Gemini,Cloud Run
# GCP_BILLING_CURRENCY=USD

# Azure OpenAI (Cost Management API + optional Azure Monitor metrics)
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...
AZURE_SUBSCRIPTION_ID=...
# Optional — override default cost scope subscriptions/AZURE_SUBSCRIPTION_ID:
# AZURE_COST_SCOPE=subscriptions/<id>
# Optional — enable per-resource token enrichment via Azure Monitor:
# AZURE_OPENAI_RESOURCE_IDS=/subscriptions/.../resourceGroups/.../providers/Microsoft.CognitiveServices/accounts/...

# AWS Bedrock (Cost Explorer + optional CloudWatch token metrics)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
# Optional — temporary credentials:
AWS_SESSION_TOKEN=...
# Optional — default region used by AWS signing helpers:
AWS_REGION=us-east-1
# Optional — enable CloudWatch token enrichment for these Bedrock regions:
AWS_BEDROCK_REGIONS=us-east-1,us-west-2
# Optional — account ID stored as metadata:
AWS_ACCOUNT_ID=123456789012
# Optional — Cost Explorer endpoint/signing region defaults to us-east-1:
# AWS_COST_EXPLORER_REGION=us-east-1

# Local SQLite database path
COSTROID_DB=~/.costroid/costroid.db

# Future cloud sync (not implemented yet)
COSTROID_ORG_KEY=csk_...
